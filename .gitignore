# ============================================================
#  Deep Freezer — .gitignore
#  Covers: ASP.NET Core (.NET 10) + Vite + TypeScript + Node
# ============================================================


# ─────────────────────────────────────────
#  SECRETS — Never commit these
# ─────────────────────────────────────────
**/appsettings.Development.json
**/*.env
**/.env
**/.env.local
**/.env.production
**/.env.*


# ─────────────────────────────────────────
#  .NET / ASP.NET Core Backend
# ─────────────────────────────────────────
# Build output
Backend/**/bin/
Backend/**/obj/

# NuGet packages
*.nupkg
*.snupkg
.nuget/
packages/

# Visual Studio artifacts
*.user
*.suo
*.userosscache
*.sln.docstates
.vs/
*.vsidx
*.vslangproj

# Rider / JetBrains
.idea/
*.DotSettings.user

# Publish output
**/publish/
**/PublishProfiles/

# Entity Framework migrations (keep if you want to track them)
# Uncomment below to exclude EF migration snapshots:
# **/Migrations/


# ─────────────────────────────────────────
#  Node.js / Frontend (Vite + TypeScript)
# ─────────────────────────────────────────
# Dependencies
Frontend/node_modules/

# Build output
Frontend/dist/
Frontend/dist-ssr/

# Cache
Frontend/.vite/
Frontend/.cache/

# TypeScript build info
Frontend/*.tsbuildinfo

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# ─────────────────────────────────────────
#  OS Generated Files
# ─────────────────────────────────────────
# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS (in case of cross-platform team)
.DS_Store
.AppleDouble
.LSOverride
._*


# ─────────────────────────────────────────
#  Editors & IDEs
# ─────────────────────────────────────────
# VS Code
.vscode/
!.vscode/extensions.json

# Vim
*.swp
*.swo

# Emacs
*~


# ─────────────────────────────────────────
#  Docker (keep Dockerfile, ignore compose overrides)
# ─────────────────────────────────────────
docker-compose.override.yml
docker-compose.*.yml
!docker-compose.yml


# ─────────────────────────────────────────
#  Misc
# ─────────────────────────────────────────
*.log
*.tmp
*.bak
*.orig
